{
    "name": "fabiodalez/faz-cookie-manager",
    "description": "Cookie consent plugin: 100% free, zero cloud dependencies. Helps you comply with GDPR, CCPA/CPRA and ePrivacy, and supports the IAB TCF v2.3 framework (TCF requires a registered CMP ID).",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Fabio D'Alessandro",
            "homepage": "https://fabiodalez.it"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "support": {
        "issues": "https://github.com/fabiodalez-dev/FAZ-Cookie-Manager/issues",
        "source": "https://github.com/fabiodalez-dev/FAZ-Cookie-Manager"
    },
    "keywords": [
        "wordpress",
        "cookie",
        "gdpr",
        "ccpa",
        "consent",
        "privacy",
        "iab-tcf"
    ],
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "szepeviktor/phpstan-wordpress": "^2.0"
    }
}
